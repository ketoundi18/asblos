# Copie ce fichier en .env.local et remplis avec tes valeurs Supabase
# Ne commite JAMAIS le fichier .env.local sur GitHub

NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta_cle_anon_public
SUPABASE_SERVICE_ROLE_KEY=ta_cle_service_role

# Sel RGPD pour empreinte IP dans logs_audit (obligatoire en prod)
# Génère : openssl rand -hex 32
AUDIT_IP_SALT=change_me_openssl_rand_hex_32

# URL publique de l'app (redirect Mollie après paiement)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mollie — uniquement si tu as une VRAIE clé test (sinon laisse commenté)
# MOLLIE_API_KEY=test_ta_vraie_cle_mollie
# ENABLE_MOLLIE=true

# Simulation paiement en local (sans Mollie) — activé par défaut
ALLOW_PAYMENT_SIMULATION=true

# Secret webhook Mollie — ajouté en ?secret= sur l'URL (Mollie n'envoie pas de header custom)
# Obligatoire en production. Même valeur dans le dashboard Mollie si webhook global configuré.
# MOLLIE_WEBHOOK_SECRET=change_me_in_production

# Cotisation inscription enfant en centimes (3000 = 30,00 €)
ENROLLMENT_FEE_CENTS=3000

# Tests e2e Playwright (compte parent de test Supabase)
E2E_PARENT_EMAIL=parent.test@example.com
E2E_PARENT_PASSWORD=change_me

# Tests e2e staff (ADMIN ou TRAVAILLEUR — accès /soutien-scolaire)
E2E_STAFF_EMAIL=staff.test@example.com
E2E_STAFF_PASSWORD=change_me
# Optionnel — compte TRAVAILLEUR/STAGIAIRE/BENEVOLE pour tests /mon-service (sinon = E2E_STAFF_*)
# E2E_CLOCK_STAFF_EMAIL=travailleur.test@example.com
# E2E_CLOCK_STAFF_PASSWORD=change_me
# CRON_SECRET=change_me_in_production
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# CI GitHub (Settings → Secrets and variables → Actions) :
# NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# E2E_PARENT_EMAIL, E2E_PARENT_PASSWORD
# E2E_STAFF_EMAIL, E2E_STAFF_PASSWORD (optionnel — tests staff skippés si absents)

# Sentry — monitoring prod uniquement (pas d'emails pour les bugs npm run dev)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Ne pas activer en local sauf test volontaire de /api/debug/sentry-test :
SENTRY_ENABLE_DEV=false
NEXT_PUBLIC_SENTRY_ENABLE_DEV=false
# Upload source maps (CI / Vercel uniquement) :
# SENTRY_ORG=ton-org
# SENTRY_PROJECT=asblos
# SENTRY_AUTH_TOKEN=ton_token_sentry

# Secret cron (clôture soldes flexibilité — route /api/cron/staff-time-settlement)
# Génère une valeur aléatoire longue. Vercel : ajoute CRON_SECRET dans les env vars du projet.
# En prod : Authorization Bearer uniquement. En local : ?secret= aussi accepté (dev).
# CRON_SECRET=change_me_in_production

# GitHub MCP (Cursor) — https://github.com/settings/tokens → scope "repo"
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_votre_token_ici

# Perplexity MCP (Cursor) — https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=pplx_votre_cle_ici

# Context7 MCP (Cursor) — optionnel, https://context7.com/dashboard pour plus de requêtes
# CONTEXT7_API_KEY=
